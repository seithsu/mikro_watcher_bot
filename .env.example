# ============================================
# Telegram
# ============================================
TOKEN=your-telegram-bot-token
CHAT_ID=123456789
# ADMIN_IDS=123456789,987654321

# ============================================
# Identity / Institution
# ============================================
INSTITUTION_NAME=My Institution
BOT_IP=

# ============================================
# MikroTik API / Transport
# ============================================
MIKROTIK_IP=192.168.88.1
MIKROTIK_USER=bot-monitor
MIKROTIK_PASS=change-me
MIKROTIK_PORT=8728
MIKROTIK_USE_SSL=false
MIKROTIK_TLS_VERIFY=false
# MIKROTIK_TLS_CA_FILE=certs\\routeros-ca.pem

# Backup transport (FTPS preferred)
MIKROTIK_FTP_TLS=true
MIKROTIK_FTP_ALLOW_INSECURE=false
MIKROTIK_FTP_PORT=21

# ============================================
# Capacity / Runtime Tuning
# ============================================
MIKROTIK_MAX_CONNECTIONS=12
MIKROTIK_RECONNECT_BASE_BACKOFF=1
MIKROTIK_RECONNECT_MAX_BACKOFF=30
# Cooldown reset_all antar retry (mencegah reconnect storm)
MIKROTIK_RESET_ALL_COOLDOWN_SEC=15
ASYNC_THREAD_WORKERS=8
# 0 = nonaktifkan reconnect proaktif berbasis umur koneksi
MIKROTIK_CONNECTION_MAX_AGE_SEC=0

# ============================================
# Monitoring Intervals
# ============================================
MONITOR_INTERVAL=300
NETWATCH_INTERVAL=15
MONITOR_LOG_INTERVAL=30
MONITOR_LOG_FETCH_LINES=100
NETWATCH_PING_CONCURRENCY=4
API_ACCOUNT_DEDUP_WINDOW_SEC=300
# Kosongkan jika tidak perlu; bisa isi banyak user dipisah koma
API_ACCOUNT_SKIP_USERS=

# Skip interface monitor by name (comma-separated)
# MONITOR_IGNORE_IFACE=lo,bridge-test
MONITOR_IGNORE_IFACE=

# VPN monitoring
MONITOR_VPN_ENABLED=true
# MONITOR_VPN_IGNORE_NAMES=vpn-hq,vpn-lama

# ============================================
# Monitoring Thresholds
# ============================================
CPU_THRESHOLD=80
RAM_THRESHOLD=90
DISK_THRESHOLD=85
PING_FAIL_THRESHOLD=3
RECOVERY_CONFIRM_COUNT=2
# Host harus stabil UP minimal N detik sebelum kirim notifikasi RECOVERY
RECOVERY_MIN_UP_SECONDS=90
# Timeout seluruh siklus netwatch berturut-turut sebelum status monitor dianggap degraded
NETWATCH_CYCLE_TIMEOUT_THRESHOLD=2
# Cooldown alert degraded agar tidak spam
NETWATCH_DEGRADED_ALERT_COOLDOWN_SEC=300
# Untuk host critical, recovery dibuat lebih konservatif (anti flapping)
CRITICAL_RECOVERY_CONFIRM_COUNT=3
CRITICAL_RECOVERY_MIN_UP_SECONDS=180
# Rasio sukses ping minimum agar host dianggap UP per siklus (0.1 - 1.0)
NETWATCH_UP_MIN_SUCCESS_RATIO=0.5
PING_COUNT=4
BRUTEFORCE_FAIL_THRESHOLD=5
# Tambahkan IP trusted agar tidak pernah kena auto-block (comma-separated)
# Contoh: AUTO_BLOCK_TRUSTED_IPS=192.168.88.10,192.168.88.1
AUTO_BLOCK_TRUSTED_IPS=

TRAFFIC_THRESHOLD_MBPS=100
TRAFFIC_LEAK_THRESHOLD_MBPS=50
# TRAFFIC_LEAK_WHITELIST=server-backup,nvr

# Top bandwidth consumer alert (queue-based)
TOP_BW_ALERT_ENABLED=true
TOP_BW_ALERT_TOP_N=3
TOP_BW_ALERT_WARN_MBPS=50
TOP_BW_ALERT_CRIT_MBPS=100
TOP_BW_ALERT_CONSECUTIVE_HITS=3
TOP_BW_ALERT_RECOVERY_HITS=2
TOP_BW_ALERT_COOLDOWN_SEC=900
TOP_BW_ALERT_MIN_TX_MBPS=1
TOP_BW_ALERT_MIN_RX_MBPS=1
TOP_BW_ALERT_INTERVAL=15

DHCP_POOL_SIZE=60
DHCP_ALERT_THRESHOLD=85

# ============================================
# Network Classification / Netwatch
# ============================================
GW_WAN=192.168.1.1
GW_INET=1.1.1.1
DNS_CHECK_DOMAIN=google.com,cloudflare.com,microsoft.com
WAN_IFACE_KEYWORDS=indibiz,ether1,wan,sfp1
LAN_IFACE_KEYWORDS=local,ether2,bridge,lan

# Optional legacy static hosts (if no dynamic queue comment mapping)
# NETWATCH_HOSTS=192.168.1.10,192.168.1.11
# SERVERS=APP1:192.168.1.10,DB1:192.168.1.11
# WIFI_APS=AP1:192.168.1.20,AP2:192.168.1.21
# Device penting yang wajib dipantau (opsional):
# CRITICAL_DEVICES=DEVICE KRITIS A:192.168.1.50,DEVICE KRITIS B:192.168.1.51
# Atau auto-discovery dari hostname DHCP lease:
# CRITICAL_DEVICE_NAMES=DEVICE KRITIS A,DEVICE KRITIS B
# Window monitor per-device (opsional), format NAMA=HH:MM-HH:MM
# CRITICAL_DEVICE_WINDOWS=DEVICE KRITIS B=07:00-17:00
# TCP_SERVICES=APP1:192.168.1.10:3306,APP2:192.168.1.12:104

# Critical ARP integrity map (IP=MAC, comma-separated)
# CRITICAL_MACS=192.168.1.10=aa:bb:cc:dd:ee:ff,192.168.1.11=11:22:33:44:55:66

# ============================================
# Schedule
# ============================================
DAILY_REPORT_HOUR=7
AUTO_BACKUP_DAY=sunday

# ============================================
# Security / Limits
# ============================================
RATE_LIMIT_PER_MINUTE=20
REBOOT_COOLDOWN=300

# Alert escalation/digest
ALERT_ESCALATION_MINUTES=15
ALERT_DIGEST_THRESHOLD=5
ALERT_DIGEST_WINDOW=300
ALERT_IPC_LOCK_STALE_SEC=15
# Jika true, monitor akan kirim alert hanya setelah admin menjalankan /start
ALERT_REQUIRE_START=false

# ============================================
# Logging
# ============================================
LOG_MAX_SIZE=1048576
LOG_BACKUP_COUNT=3
